<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.mes.factory.mapper.UserMapper">
    <select id="findByLoginId" resultType="com.mes.factory.dto.UserDto">
        SELECT *
        FROM users
        WHERE login_id = #{loginId}
    </select>

    <insert id="insertUser">
        INSERT INTO users (login_id, password, user_name, role)
        VALUES (#{loginId}, #{password}, #{userName}, #{role})
    </insert>

    <select id="countByLoginId" resultType="int">
        SELECT COUNT(*)
        FROM users
        WHERE login_id = #{loginId}
    </select>

</mapper>